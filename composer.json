{
    "name": "javaabu/mobile-verification",
    "description": "Adds mobile number verification to Laravel projects.",
    "homepage": "https://github.com/Javaabu/mobile-verification",
    "license": "MIT",
    "authors": [
        {
            "name": "Arushad Ahmed",
            "email": "arushad@javaabu.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "javaabu/sms-notifications": "^1.3",
        "javaabu/laravel-recaptcha": "^6.3",
        "javaabu/helpers": "^1.71",
        "javaabu/activitylog": "^1.6",
        "laravel/passport": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.16 || ^10.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.5.3 || ^12.5.8 || ^13.0.3",
        "laravel/pint": "^1.15",
        "javaabu/auth": "^2.0"
    },
    "suggest": {
        "javaabu/auth": "Required for login and registration"
    },
    "autoload": {
        "psr-4": {
            "Javaabu\\MobileVerification\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Javaabu\\MobileVerification\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        },
        "laravel": {
            "providers": [
                "Javaabu\\MobileVerification\\MobileVerificationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
